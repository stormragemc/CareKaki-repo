# Root .env for `docker compose up` (loaded automatically from this directory).
# All keys are OPTIONAL — the stack boots with synthetic/demo data when left blank.
# These values are passed through to the backend container (see docker-compose.yml).

# LLM (chat/guardian use synthetic responses when empty)
OPENAI_API_KEY=

# Telegram caregiver bot
TELEGRAM_BOT_TOKEN=

# Telegram ICCP handover bot
ICCP_BOT_TELEGRAM_TOKEN=

# OpenFDA medication lookups
OPENFDA_API_TOKEN=

# ── Audio Guide (ElevenLabs voice) ──────────────────────────────────────────
# Powers the spoken guide / tutorial narration. BOTH the API key AND a voice ID
# are required — with only the key you'll get a script but no audio. Leave blank
# to keep the guide silent (text-only fallback).
# 1) API key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# 2) Voice ID: ElevenLabs → Voices → pick a voice → copy its ID
#    (e.g. 21m00Tcm4TlvDq8ikWAM)
ELEVENLABS_VOICE_ID=
# 3) Model (optional; this is the default)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Telegram webhooks via ngrok (only needed for the live Telegram bot demo) ──
# Used by `docker compose --profile webhook up`, which starts an ngrok tunnel to
# the backend so Telegram can deliver webhook updates to your machine.
#
# 1) Get a token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# 2) Reserve a free static domain at https://dashboard.ngrok.com/domains
#    (host only, no https://), e.g. gone-target-smugness.ngrok-free.dev
NGROK_DOMAIN=
# 3) The full public URL the backend registers its webhooks against.
#    Must match NGROK_DOMAIN, e.g. https://gone-target-smugness.ngrok-free.dev
PUBLIC_BASE_URL=
