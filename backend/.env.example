# Backend env. All keys are OPTIONAL — the server boots on synthetic/demo data
# when blank (Guardian, health, emergency routing all work offline).
# Copy to `.env` and fill in only what you need. DO NOT commit real secrets here.

# LLM (chat/extraction/pathway use synthetic responses when empty)
OPENAI_API_KEY=

# Telegram caregiver bot
TELEGRAM_BOT_TOKEN=

# Telegram ICCP coordinator bot
ICCP_BOT_TELEGRAM_TOKEN=

# OpenFDA medication lookups
OPENFDA_API_TOKEN=

# Audio Guide (ElevenLabs voice). BOTH the API key AND a voice ID are required —
# with only the key the guide produces a script but stays silent. Leave blank
# for the text-only fallback.
#   API key:  https://elevenlabs.io/app/settings/api-keys
#   Voice ID: ElevenLabs → Voices → pick a voice → copy its ID (e.g. 21m00Tcm4TlvDq8ikWAM)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Public HTTPS base URL Telegram should call back on (your ngrok domain).
# When set, the backend auto-registers /telegram/webhook and /iccp/webhook on
# startup — no manual "telegram connect link" step needed.
# e.g. https://your-domain.ngrok-free.dev
PUBLIC_BASE_URL=

# ── Manual (non-Docker) run ──
# 1) ngrok http --domain=<your-static-domain> 8000    (terminal 1)
# 2) python -m uvicorn main:app --reload --port 8000   (terminal 2)
# 3) npm run dev                                        (terminal 3, from repo root)
#
# ── Docker run (auto ngrok + webhook registration) ──
# From the repo root: docker compose --profile webhook up --build
# (set NGROK_AUTHTOKEN, NGROK_DOMAIN, PUBLIC_BASE_URL in the root .env first)
